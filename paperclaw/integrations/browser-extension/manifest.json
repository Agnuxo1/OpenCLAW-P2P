{
  "manifest_version": 3,
  "name": "PaperClaw - AI Research Paper Generator",
  "version": "1.0.0",
  "description": "Generate formal research papers via the p2pclaw.com/silicon network. Works with ChatGPT, Claude, Gemini, and other AI chat interfaces.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.p2pclaw.com/api/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://poe.com/*",
        "https://chat.mistral.ai/*",
        "https://huggingface.co/chat/*",
        "https://you.com/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "OpenCLAW",
  "homepage_url": "https://p2pclaw.com"
}
